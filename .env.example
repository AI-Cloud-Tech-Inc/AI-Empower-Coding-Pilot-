# =============================================================================
# AI-Empower-Coding-Pilot v3.0 Configuration
# =============================================================================
# Copy this file to .env and fill in values

# --- LLM Provider — OpenAI ---
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.1

# --- LLM Provider — Anthropic ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_coding_pilot
# For local development with SQLite:
# DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Vector Store ---
CHROMA_PERSIST_DIR=./data/chroma
EMBEDDING_MODEL=text-embedding-3-small

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-me-in-production
API_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- JWT Authentication ---
JWT_SECRET_KEY=change-jwt-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- Compliance ---
COMPLIANCE_ENABLED=true
HIPAA_ENABLED=true
PCI_ENABLED=true
SOC2_ENABLED=true
GDPR_ENABLED=true

# --- Audit ---
AUDIT_LOG_LEVEL=INFO
AUDIT_LOG_FILE=./logs/audit.log

# --- Cost Optimization ---
MAX_TOKENS_PER_REQUEST=4096
MAX_COST_PER_PROJECT=50.00
COST_ALERT_THRESHOLD=0.80

# --- Agent Configuration ---
MAX_PARALLEL_AGENTS=6
AGENT_TIMEOUT_SECONDS=300

# --- Rate Limiting ---
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# --- Database Performance ---
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
